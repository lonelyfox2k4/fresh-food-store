<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee
                      http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
  version="4.0"
  metadata-complete="false">

    <display-name>Fresh Food Store Admin</display-name>

    <!-- Servlets -->
    <servlet>
        <servlet-name>ProductServlet</servlet-name>
        <servlet-class>org.example.controller.ProductServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ProductServlet</servlet-name>
        <url-pattern>/manager/products</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>CategoryServlet</servlet-name>
        <servlet-class>org.example.controller.CategoryServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>CategoryServlet</servlet-name>
        <url-pattern>/manager/categories</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>SupplierServlet</servlet-name>
        <servlet-class>org.example.controller.SupplierServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>SupplierServlet</servlet-name>
        <url-pattern>/manager/suppliers</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>PricingServlet</servlet-name>
        <servlet-class>org.example.controller.PricingServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>PricingServlet</servlet-name>
        <url-pattern>/manager/inventory-pricing</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>InventoryServlet</servlet-name>
        <servlet-class>org.example.controller.InventoryServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>InventoryServlet</servlet-name>
        <url-pattern>/manager/inventory</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>GoodsReceiptServlet</servlet-name>
        <servlet-class>org.example.controller.GoodsReceiptServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>GoodsReceiptServlet</servlet-name>
        <url-pattern>/manager/goods-receipts</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>PolicyServlet</servlet-name>
        <servlet-class>org.example.controller.PolicyServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>PolicyServlet</servlet-name>
        <url-pattern>/manager/policies</url-pattern>
    </servlet-mapping>

    <filter>
        <filter-name>EncodingFilter</filter-name>
        <filter-class>org.example.filter.EncodingFilter</filter-class>
    </filter>
    <filter-mapping>
        <filter-name>EncodingFilter</filter-name>
        <url-pattern>/*</url-pattern>
    </filter-mapping>

    <welcome-file-list>
        <welcome-file>home</welcome-file>
    </welcome-file-list>

</web-app>
